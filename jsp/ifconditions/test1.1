}
</style>

</head>
<body>
<h2>comparison</h2>
<form method="post">
enter a:<input type="number" name="a" required><br><br>b

enter b:<input type="number" name="b" required><br><br>

<button type="submit">Compare</button>
</form>
<%
//logic only run if the form has been submitted
